[tool_call] Write({"file_path":"/Users/yosefshachnovsky/dev/copypaste/src/copypaste/app.py","content":"from flask import Flask, current_app, jsonify, make_response, redirect, render_template, url_for\nfrom flask_wtf import CSRFProtect\n\nfrom copypaste import db\nfrom copypaste.config import Config\nfrom copypaste.forms import CreatePasteForm\n\n\ndef create_app(table=None) -> Flask:\n    app = Flask(__name__)\n    app.config.from_object(Config)\n\n    if table is None:\n        resource = db.get_resource()\n        table = db.create_table(resource)\n    app.config[\"PASTE_TABLE\"] = table\n\n    CSRFProtect(app)\n\n    @app.get(\"/healthz\")\n    def healthz():\n        return jsonify({\"status\": \"ok\"})\n\n    @app.get(\"/\")\n    def create_form():\n        return render_template(\"create.html\", form=CreatePasteForm())\n\n    @app.post(\"/\")\n    def create_paste():\n        form = CreatePasteForm()\n        if not form.validate_on_submit():\n            return render_template(\"create.html\", form=form), 400\n\n        try:\n            paste_id = db.put_paste(current_app.config[\"PASTE_TABLE\"], form.content.data)\n        except db.PasteTooLargeError:\n            max_kb = db.MAX_PASTE_SIZE_BYTES // 1024\n            form.content.errors.append(f\"Paste is too large (max {max_kb}KB).\")\n            return render_template(\"create.html\", form=form), 400\n\n        return redirect(url_for(\"view_paste\", paste_id=paste_id))\n\n    @app.get(\"/<paste_id>\")\n    def view_paste(paste_id):\n        content = db.get_paste(current_app.config[\"PASTE_TABLE\"], paste_id)\n        if content is None:\n            return render_template(\"404.html\"), 404\n\n        response = make_response(render_template(\"view.html\", content=content))\n        response.headers[\"Cache-Control\"] = \"public, max-age=31536000, immutable\"\n        return response\n\n    return app\n"})

